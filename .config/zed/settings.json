// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true,
  },
  "project_panel": {
    "hide_hidden": false,
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },
  "relative_line_numbers": "enabled",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "soft_wrap": "editor_width",
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
    },
  },
  "languages": {
    "CSS": {
      "language_servers": ["tailwind-language-server"],
    },
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "buffer_font_features": {
    "calt": 0,
  },
  "buffer_font_family": "NotoSansM Nerd Font",
  "ui_font_family": "Noto Sans",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha",
  },
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha - No Italics",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        // For JavaScript:
        "javascript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "none",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": {
              "enabled": false,
            },
            "variableTypes": {
              "enabled": false,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": {
              "enabled": false,
            },
            "functionLikeReturnTypes": {
              "enabled": false,
            },
            "enumMemberValues": {
              "enabled": false,
            },
          },
        },
        // For TypeScript:
        "typescript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "none",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": {
              "enabled": false,
            },
            "variableTypes": {
              "enabled": false,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": {
              "enabled": false,
            },
            "functionLikeReturnTypes": {
              "enabled": false,
            },
            "enumMemberValues": {
              "enabled": false,
            },
          },
        },
      },
    },
  },
}
